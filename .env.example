# API Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# Redis Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=86400

# Scraping Configuration
REQUEST_TIMEOUT=15
MAX_CONTENT_LENGTH=10000
USER_AGENT=Mozilla/5.0 (compatible; PublisherClassifier/1.0)

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_POLICIES=3

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
